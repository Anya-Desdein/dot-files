#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GLOBAL=0

for arg in "$@"; do
    case "$arg" in
        --global|--system) GLOBAL=1 ;;
        *) echo "Unknown argument: $arg" >&2; exit 1 ;;
    esac
done

if (( GLOBAL )); then
    SYSTEMD_DIR="/etc/systemd/system"
    SYSTEMCTL="systemctl"
    if [[ $EUID -ne 0 ]]; then
        echo "Global installation requires root. Re-run with sudo." >&2
        exit 1
    fi
else
    SYSTEMD_DIR="$HOME/.config/systemd/user"
    SYSTEMCTL="systemctl --user"
fi

mkdir -p "$SYSTEMD_DIR"

install -m755 "$SCRIPT_DIR/redshift-daemon" "$HOME/.local/bin/redshift-daemon"
install -m644 "$SCRIPT_DIR/redshift.service" "$SYSTEMD_DIR/redshift.service"

$SYSTEMCTL daemon-reload
$SYSTEMCTL enable --now redshift.service

echo "redshift.service enabled and started."