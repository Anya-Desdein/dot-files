#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GLOBAL=0

for arg in "$@"; do
    case "$arg" in
        --global|--system) GLOBAL=1 ;;
        *) echo "Unknown argument: $arg" >&2; exit 1 ;;
    esac
done

if (( GLOBAL )); then
    SYSTEMD_DIR="/etc/systemd/system"
    SYSTEMCTL="systemctl"
    if [[ $EUID -ne 0 ]]; then
        echo "Global installation requires root. Re-run with sudo." >&2
        exit 1
    fi
else
    SYSTEMD_DIR="$HOME/.config/systemd/user"
    SYSTEMCTL="systemctl --user"
fi

mkdir -p "$SYSTEMD_DIR"

install -m644 "$SCRIPT_DIR/redshift-enable" "$SYSTEMD_DIR/redshift-enable.timer"
cat > "$SYSTEMD_DIR/redshift-enable.service" <<'EOF'
[Unit]
Description=Enable redshift night mode

[Service]
Type=oneshot
ExecStart=redshift -O 2900
EOF

install -m644 "$SCRIPT_DIR/redshift-disable" "$SYSTEMD_DIR/redshift-disable.timer"
cat > "$SYSTEMD_DIR/redshift-disable.service" <<'EOF'
[Unit]
Description=Reset redshift to day mode

[Service]
Type=oneshot
ExecStart=redshift -x
EOF

$SYSTEMCTL daemon-reload
$SYSTEMCTL enable --now redshift-enable.timer
$SYSTEMCTL enable --now redshift-disable.timer

echo "Timers enabled. Next trigger times:"
$SYSTEMCTL list-timers redshift-enable.timer redshift-disable.timer
