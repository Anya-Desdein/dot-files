#!/bin/bash
# Script to suspend to RAM if SWAYSTATUS_ENABLE_SUSPEND_TO_RAM is TRUE

if [ "$SWAYSTATUS_ENABLE_SUSPEND_TO_RAM" != "TRUE" ]; then
    echo "SWAYSTATUS_ENABLE_SUSPEND_TO_RAM feature NOT enabled. Exiting."
    exit 0
fi

if ! command -v systemctl &> /dev/null; then
    echo "Error: systemctl command not found. Cannot suspend."
    exit 1
fi

if command -v notify-send &> /dev/null; then
    notify_id=$(notify-send --print-id -u critical "System will SUSPEND to RAM in 30 seconds...")
    for sec in $(seq 29 -1 1); do
        sleep 1
        notify_id=$(notify-send --print-id --replace-id="$notify_id" -u critical "System will SUSPEND to RAM in ${sec} seconds...")
    done
else
    echo "Warning: notify-send not found. System will SUSPEND to RAM in 30 seconds..."
    sleep 30
fi

dbus-send --system --print-reply --dest=org.freedesktop.login1 \
    /org/freedesktop/login1 org.freedesktop.login1.Manager.Suspend boolean:false
