#!/usr/bin/env bash
set -e

GLOBAL=0

for arg in "$@"; do
    case "$arg" in
        --global|--system) GLOBAL=1 ;;
        *) echo "Unknown argument: $arg" >&2; exit 1 ;;
    esac
done

if (( GLOBAL )); then
    SYSTEMD_DIR="/etc/systemd/system"
    SYSTEMCTL="systemctl"
    if [[ $EUID -ne 0 ]]; then
        echo "Global uninstall requires root. Re-run with sudo." >&2
        exit 1
    fi
else
    SYSTEMD_DIR="$HOME/.config/systemd/user"
    SYSTEMCTL="systemctl --user"
fi

$SYSTEMCTL disable --now redshift-sched.service 2>/dev/null && echo "Disabled redshift-sched.service" || true
rm -f "$SYSTEMD_DIR/redshift-sched.service" && echo "Removed $SYSTEMD_DIR/redshift-sched.service" || true
rm -f "$HOME/.local/bin/redshift-daemon" && echo "Removed $HOME/.local/bin/redshift-daemon" || true

$SYSTEMCTL daemon-reload
echo "Done."