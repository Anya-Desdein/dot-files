#!/usr/bin/env bash
set -e

GLOBAL=0

for arg in "$@"; do
    case "$arg" in
        --global|--system) GLOBAL=1 ;;
        *) echo "Unknown argument: $arg" >&2; exit 1 ;;
    esac
done

if (( GLOBAL )); then
    SYSTEMD_DIR="/etc/systemd/system"
    SYSTEMCTL="systemctl"
    if [[ $EUID -ne 0 ]]; then
        echo "Global uninstall requires root. Re-run with sudo." >&2
        exit 1
    fi
else
    SYSTEMD_DIR="$HOME/.config/systemd/user"
    SYSTEMCTL="systemctl --user"
fi

UNITS=(
    redshift-enable.timer
    redshift-enable.service
    redshift-disable.timer
    redshift-disable.service
)

for unit in "${UNITS[@]}"; do
    $SYSTEMCTL disable --now "$unit" 2>/dev/null && echo "Disabled $unit" || true
    rm -f "$SYSTEMD_DIR/$unit" && echo "Removed $SYSTEMD_DIR/$unit" || true
done

$SYSTEMCTL daemon-reload
echo "Done."
